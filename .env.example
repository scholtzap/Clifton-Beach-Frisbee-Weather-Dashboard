# Beach Weather Dashboard - Environment Variables
# Copy this file to .env and fill in your actual API keys

# Location Configuration
# Options: clifton, praia
LOCATION=clifton

# Port for development server (default: 8080)
PORT=8080

# API Keys
# Get your OpenWeatherMap API key from: https://openweathermap.org/api
OWM_API_KEY=your_openweathermap_api_key_here

# Get your StormGlass API key from: https://stormglass.io/
STORMGLASS_API_KEY=your_stormglass_api_key_here

# Server/CI only: Places key for scripts/fetch-busyness.py (GitHub Actions).
# Do NOT use your browser-restricted Maps key here — create a separate key with API restrictions only.
GOOGLE_API_KEY=your_server_places_api_key_here

# Browser key: YouTube Data API v3, HTTP referrer restricted to your GitHub Pages URL.
# Required when youtube_search.enabled is true in config.yml (build-html.js embeds it in index.html).
YOUTUBE_API_KEY=your_youtube_browser_api_key_here

# Note: Google Place IDs are now configured in config.yml
# Each location has its own google_place_id in the configuration file
# No need to set GOOGLE_PLACE_ID here - it will be read from config.yml automatically
